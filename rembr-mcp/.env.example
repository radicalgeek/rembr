# Database (component-based connection, preferred for production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rembr
DB_USER=rembr_app
DB_PASSWORD=your-db-password
DB_READ_HOST=localhost
DB_READ_PASSWORD=your-db-password

# Or use a connection string (takes precedence if set)
# DATABASE_URL="postgresql://rembr_app:password@localhost:5432/rembr"

# Redis (session store + embedding cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
# Or use a URL (takes precedence if set)
# REDIS_URL="redis://:password@localhost:6379"

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET="your-jwt-secret-here"

# Ollama Embedding Service
OLLAMA_HOST="http://localhost:11434"

# Server Configuration
PORT=3000
NODE_ENV=production
PUBLIC_URL="https://rembr.ai"
UI_BASE_URL="https://rembr.ai"

# Auto-optimization
ENABLE_OPTIMIZATION=true

# CORS (comma-separated origins for development)
CORS_ORIGIN="http://localhost:3000"

# ─── Security (REM-28) ─────────────────────────────────────────────────────────
# REQUIRED in production. Generate with: openssl rand -hex 32

# Admin endpoints authentication (X-Admin-Key header) — RAD-45
# Required: server refuses to start if this is not set.
# All /admin/* routes check this key. Generate: openssl rand -hex 32
ADMIN_API_KEY="change-me-generate-with-openssl-rand-hex-32"

# Prometheus /metrics endpoint authentication (Bearer token or X-Metrics-Token header)
# In production: MUST be set — /metrics returns 403 without this.
# In development: optional (endpoint is open if unset).
METRICS_SECRET="change-me-generate-with-openssl-rand-hex-32"

# ─── Contradiction Detection Tuning (RAD-62) ──────────────────────────────────
# Per-LLM-call timeout (ms) for background contradiction analysis.
# Default: 8000ms. Increase on dedicated GPU; decrease to fail fast under contention.
# CONTRADICTION_DETECTION_TIMEOUT_MS=8000

# Max similar memories to check per store_memory call (caps total LLM calls).
# Default: 5. Lower values reduce GPU contention; raise if coverage matters more.
# CONTRADICTION_MAX_CANDIDATES=5

# Ollama model for contradiction analysis.
# Defaults to OLLAMA_TEXT_MODEL (llama3.1:8b). Use a faster/smaller model to
# reduce GPU contention with the embedding model (nomic-embed-text).
# Examples: qwen2:1.5b, tinyllama, phi3.5-mini
# OLLAMA_CONTRADICTION_MODEL=llama3.1:8b
