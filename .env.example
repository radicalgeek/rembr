# Rembr self-hosted stack configuration (docker compose).
# Copy to .env and adjust. See SELF-HOSTING.md.

# Postgres password (also embedded in DATABASE_URL for the engine)
POSTGRES_PASSWORD=change-me

# Required by the engine for JWT signing — set a long random value
JWT_SECRET=change-me-to-a-long-random-string

# API key for the console (printed by rembr-mcp/scripts/bootstrap-tenant.mjs)
REMBR_API_KEY=

# Embeddings: default is local Ollama (start with: docker compose --profile ollama up -d)
# then pull the model once: docker compose exec ollama ollama pull nomic-embed-text
EMBEDDING_PROVIDER=ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Or any OpenAI-compatible endpoint instead:
# EMBEDDING_PROVIDER=openai-compatible
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
